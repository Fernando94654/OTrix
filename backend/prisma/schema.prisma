// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
// Get DATABASE_URL from .env file

generator client {
  provider = "prisma-client"
  engineType  = "library"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String       @id @default(uuid())
  name       String
  last_name  String
  email      String       @unique
  company_id String?
  password   String
  birthday   DateTime?
  gender     Gender?
  role       Role
  created_at DateTime?
  company    Company?      @relation(fields: [company_id], references: [id])

  sessions    Session[]
  levelsPlayed LevelPlayed[]

  @@index([company_id])
  @@map("users")
}

model Level {
  id         Int          @id @default(autoincrement())
  name       String?
  max_score  Int?
  difficulty String?

  levelsPlayed LevelPlayed[]

  @@map("level")
}

model Session {
  id                       String   @id @default(uuid())
  user_id                  String
  refresh_token            String
  refresh_token_expires_at DateTime
  created_at               DateTime?

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("sessions")
}

model Company {
  id    String @id @default(uuid())
  name  String?

  users User[]

  @@map("companies")
}

model LevelPlayed {
  id        String   @id  @default(uuid())
  user_id   String
  level_id  Int
  score     Int?
  attempts  Int?
  time_used Int?
  date      DateTime?

  user  User  @relation(fields: [user_id], references: [id])
  level Level @relation(fields: [level_id], references: [id])

  @@index([user_id])
  @@index([level_id])
  @@map("level_played")
}

model ApiKey {
  id          String   @id @default(uuid())
  name        String
  keyHash     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}


enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Role {
  USER
  ADMIN
}