// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
// Get DATABASE_URL from .env file

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String       @id
  email      String       @unique
  password   String
  birthday   DateTime?
  gender     Boolean?
  admin      Boolean
  company    String
  created_at DateTime?

  client      Client       @relation(fields: [company], references: [id])
  sessions    Session[]
  levelsPlayed LevelPlayed[]

  @@index([company])
  @@map("users")
}

model Level {
  id         Int          @id
  name       String?
  max_score  Int?
  difficulty String?

  levelsPlayed LevelPlayed[]

  @@map("level")
}

model Session {
  id                       String   @id
  user_id                  String
  refresh_token            String
  refresh_token_expires_at DateTime
  created_at               DateTime?

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("sessions")
}

model Client {
  id    String @id
  name  String?

  users User[]

  @@map("clients")
}

model LevelPlayed {
  id        String   @id
  user_id   String
  level_id  Int
  score     Int?
  attempts  Int?
  time_used Int?
  date      DateTime?

  user  User  @relation(fields: [user_id], references: [id])
  level Level @relation(fields: [level_id], references: [id])

  @@index([user_id])
  @@index([level_id])
  @@map("level_played")
}


