// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
// Get DATABASE_URL from .env file

generator client {
  provider = "prisma-client"
  engineType  = "library"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String       @id @default(uuid())
  name       String
  last_name  String
  email      String       @unique
  company_id String?
  password   String
  birthday   DateTime?
  gender     Gender?
  role       Role @default(USER)
  created_at DateTime?
  company    Company?      @relation(fields: [company_id], references: [id])

  sessions    Session[]
  levelsPlayed LevelPlayed[]
  stats        UserLevelStats[]

  @@index([company_id])
  @@map("users")
}

model Level {
  id         Int          @id @default(autoincrement())
  name       String?
  max_score  Int?
  difficulty String?

  levelsPlayed LevelPlayed[]
  stats        UserLevelStats[]
  
  @@map("level")
}

model Session {
  id                       String   @id @default(uuid())
  user_id                  String
  refresh_token            String
  refresh_token_expires_at DateTime
  created_at               DateTime?

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("sessions")
}

model Company {
  id    String @id @default(uuid())
  name  String?

  users User[]

  @@map("companies")
}

model LevelPlayed {
  id        String   @id  @default(uuid())
  user_id   String
  level_id  Int
  score     Int?
  attempts  Int?
  time_used Int?
  date      DateTime?

  user  User  @relation(fields: [user_id], references: [id])
  level Level @relation(fields: [level_id], references: [id])

  @@index([user_id])
  @@index([level_id])
  @@map("level_played")
}

model UserLevelStats {
  user_id        String
  level_id       Int
  best_score     Int      @default(0)
  best_time      Int?     // En segundos o milisegundos
  total_attempts Int      @default(0)
  last_played    DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [id])
  level Level @relation(fields: [level_id], references: [id])

  @@id([user_id, level_id]) // Llave primaria compuesta
  @@map("user_level_stats")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Role {
  USER
  ADMIN
}